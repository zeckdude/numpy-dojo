# Optional — PostHog (analytics + client error tracking). Leave unset to disable.
# NEXT_PUBLIC_POSTHOG_TOKEN=
# Optional — server-only copy of the same token (Node never requires this; use if you stop exposing the public var).
# POSTHOG_SERVER_TOKEN=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# NEXT_PUBLIC_POSTHOG_DEBUG=1
# Dev only — enables GET /api/posthog-server-test to send one test server exception to PostHog.
# POSTHOG_SERVER_TEST=1
#
# Optional — force the `environment` super property (filter in PostHog by environment):
# development | staging | preview | production. If unset, uses VERCEL_ENV when deployed; local next dev → development.
# NEXT_PUBLIC_POSTHOG_ENV=staging
