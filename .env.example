# Public site origin for `metadataBase` and `og:url` (no trailing slash). REQUIRED on preview/staging (Firebase, Vercel preview).
# `og:image` / `twitter:image` always use https://www.numpydojo.com/og/default.png regardless of this value.
# Production: https://www.numpydojo.com
# NEXT_PUBLIC_SITE_URL=https://www.numpydojo.com
#
# Optional — PostHog (analytics + client error tracking). Leave unset to disable.
# NEXT_PUBLIC_POSTHOG_TOKEN=
# Optional — server-only copy of the same token (Node never requires this; use if you stop exposing the public var).
# POSTHOG_SERVER_TOKEN=
# Ingest API (browser + posthog-node both read NEXT_PUBLIC_POSTHOG_HOST):
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Managed reverse proxy: CNAME a → *.proxyhog.com in DNS (neutral subdomain; avoid posthog/ph in the hostname).
# No path — HTTPS origin only:
# NEXT_PUBLIC_POSTHOG_HOST=https://a.numpydojo.com
# When api_host is your domain, ui_host defaults to https://us.posthog.com. EU projects: set explicitly:
# NEXT_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com
# NEXT_PUBLIC_POSTHOG_DEBUG=1
# Dev only — enables GET /api/posthog-server-test to send one test server exception to PostHog.
# POSTHOG_SERVER_TEST=1
#
# Optional — force the `environment` super property (filter in PostHog by environment):
# development | staging | preview | production. If unset, uses VERCEL_ENV when deployed; local next dev → development.
# NEXT_PUBLIC_POSTHOG_ENV=staging
